# ============================================================
# SniperBot 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# Polygon 钱包私钥（禁止外泄！）
PRIVATE_KEY=0x_your_private_key_here

# Polymarket CLOB API
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# API 凭证（首次运行会自动派生）
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Funder 地址（Gnosis Safe 代理地址）
FUNDER_ADDRESS=0x_your_funder_address

# Polygon RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# 初始余额（仅用于首次统计初始化）
INITIAL_BALANCE=1000

# 日志级别
LOG_LEVEL=INFO
